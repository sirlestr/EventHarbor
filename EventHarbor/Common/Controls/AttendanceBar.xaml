<UserControl x:Class="EventHarbor.Common.Controls.AttendanceBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="{Binding BarHeight, RelativeSource={RelativeSource Self}}">
    <Grid x:Name="Root" ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="Seg0" Grid.Column="0" Background="{DynamicResource AttendChildrenBrush}"/>
        <Border x:Name="Seg1" Grid.Column="1" Background="{DynamicResource AttendAdultsBrush}"/>
        <Border x:Name="Seg2" Grid.Column="2" Background="{DynamicResource AttendSeniorsBrush}"/>
        <Border x:Name="Seg3" Grid.Column="3" Background="{DynamicResource AttendDisabledBrush}"/>
        <TextBlock x:Name="EmptyLabel" Text="Zatím bez záznamu"
                   FontSize="12" Foreground="{DynamicResource InkSubtleBrush}"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"
                   Grid.Column="0" Grid.ColumnSpan="4"/>
    </Grid>
</UserControl>
