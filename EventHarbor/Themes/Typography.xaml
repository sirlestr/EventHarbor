<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bundled fonts via pack URI. Geist is variable; Instrument Serif has Regular + Italic. -->
    <FontFamily x:Key="SansFont">pack://application:,,,/Resources/Fonts/#Geist</FontFamily>
    <FontFamily x:Key="SerifFont">pack://application:,,,/Resources/Fonts/#Instrument Serif</FontFamily>
    <!-- No Geist Mono shipped yet; tabular numerics use Cascadia / Consolas fallback. -->
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
    </Style>

    <Style x:Key="SubtleText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{DynamicResource InkSubtleBrush}"/>
        <Setter Property="FontSize" Value="11.5"/>
    </Style>

    <Style x:Key="SerifHeading" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SerifFont}"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
    </Style>

    <Style x:Key="SerifTitle" TargetType="TextBlock" BasedOn="{StaticResource SerifHeading}">
        <Setter Property="FontSize" Value="32"/>
    </Style>

    <Style x:Key="SerifDisplay" TargetType="TextBlock" BasedOn="{StaticResource SerifHeading}">
        <Setter Property="FontSize" Value="46"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{DynamicResource InkSubtleBrush}"/>
    </Style>

    <Style x:Key="EyebrowText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource InkSubtleBrush}"/>
    </Style>
</ResourceDictionary>
