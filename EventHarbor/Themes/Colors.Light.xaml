<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Warm museum palette (light) -->
    <Color x:Key="BgColor">#FAF8F3</Color>
    <Color x:Key="BgSubtleColor">#F4F0E8</Color>
    <Color x:Key="BgElevatedColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E8E2D5</Color>
    <Color x:Key="BorderStrongColor">#D4CBB8</Color>
    <Color x:Key="InkColor">#1A1713</Color>
    <Color x:Key="InkMutedColor">#5A5147</Color>
    <Color x:Key="InkSubtleColor">#8A8174</Color>

    <!-- Accent: deep navy -->
    <Color x:Key="AccentColor">#1E3A5F</Color>
    <Color x:Key="AccentHoverColor">#2A4A75</Color>
    <Color x:Key="AccentTintColor">#E8EEF5</Color>
    <Color x:Key="AccentDeepColor">#13243C</Color>

    <!-- Semantic -->
    <Color x:Key="CopperColor">#B85C1F</Color>
    <Color x:Key="CopperTintColor">#FAEFE3</Color>
    <Color x:Key="MossColor">#4A6B3D</Color>
    <Color x:Key="MossTintColor">#EDF2E6</Color>
    <Color x:Key="WarnColor">#8B4513</Color>

    <!-- Attendance (fixed across themes) -->
    <Color x:Key="AttendChildrenColor">#1E3A5F</Color>
    <Color x:Key="AttendAdultsColor">#4A7BA8</Color>
    <Color x:Key="AttendSeniorsColor">#B85C1F</Color>
    <Color x:Key="AttendDisabledColor">#8B4513</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="BgSubtleBrush" Color="{StaticResource BgSubtleColor}"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}"/>
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMutedColor}"/>
    <SolidColorBrush x:Key="InkSubtleBrush" Color="{StaticResource InkSubtleColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTintColor}"/>
    <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeepColor}"/>
    <SolidColorBrush x:Key="CopperBrush" Color="{StaticResource CopperColor}"/>
    <SolidColorBrush x:Key="CopperTintBrush" Color="{StaticResource CopperTintColor}"/>
    <SolidColorBrush x:Key="MossBrush" Color="{StaticResource MossColor}"/>
    <SolidColorBrush x:Key="MossTintBrush" Color="{StaticResource MossTintColor}"/>
    <SolidColorBrush x:Key="AttendChildrenBrush" Color="{StaticResource AttendChildrenColor}"/>
    <SolidColorBrush x:Key="AttendAdultsBrush" Color="{StaticResource AttendAdultsColor}"/>
    <SolidColorBrush x:Key="AttendSeniorsBrush" Color="{StaticResource AttendSeniorsColor}"/>
    <SolidColorBrush x:Key="AttendDisabledBrush" Color="{StaticResource AttendDisabledColor}"/>
</ResourceDictionary>
