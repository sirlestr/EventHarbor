<Window x:Class="EventHarbor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shell="clr-namespace:EventHarbor.Views.Shell"
        xmlns:list="clr-namespace:EventHarbor.Views.List"
        xmlns:form="clr-namespace:EventHarbor.Views.Form"
        xmlns:stats="clr-namespace:EventHarbor.Views.Stats"
        xmlns:vm="clr-namespace:EventHarbor.ViewModels"
        Title="EventHarbor"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ListViewModel}">
            <list:ListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FormViewModel}">
            <form:FormView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatsViewModel}">
            <stats:StatsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <shell:SidebarView Grid.Column="0"/>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>
