<UserControl x:Class="EventHarbor.Views.Shell.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
             d:DataContext="{d:DesignInstance Type=vm:MainShellViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgSubtleBrush}">
    <UserControl.Resources>
        <!-- Primary nav (Vsechny akce / Statistiky) - active state shown as elevated bg + ink -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip-style item with toggled active state -->
        <Style x:Key="FilterItem" TargetType="Button" BasedOn="{StaticResource NavItem}">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Brand -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,18,12,18">
            <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource AccentBrush}">
                <TextBlock Text="E" FontFamily="{StaticResource SerifFont}"
                           FontSize="18" FontStyle="Italic"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="EventHarbor" FontFamily="{StaticResource SerifFont}"
                           FontSize="20" Foreground="{DynamicResource InkBrush}"/>
                <TextBlock Text="KULTURNÍ AGENDA" FontSize="10.5" FontWeight="Medium"
                           Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Nav + filters (scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,0,12,12">
                <TextBlock Text="PŘEHLED" Style="{StaticResource EyebrowText}" Margin="10,8,10,6"/>

                <!-- Vsechny akce -->
                <Button Command="{Binding GoToCommand}" CommandParameter="List">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentRoute}" Value="List">
                                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="list" Size="16" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Všechny akce" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Background="{DynamicResource BgSubtleBrush}" CornerRadius="10" Padding="7,2">
                            <TextBlock Text="{Binding TotalCount}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource InkSubtleBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Statistiky -->
                <Button Command="{Binding GoToCommand}" CommandParameter="Stats">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentRoute}" Value="Stats">
                                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="chart" Size="16" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Statistiky" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Nova akce (primary mini) -->
                <Button Style="{StaticResource NavItem}" Margin="0,6,0,0"
                        Background="{DynamicResource AccentBrush}" Foreground="White"
                        Command="{Binding StartNewFromSidebarCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="plus" Size="14" Margin="0,0,10,0" Foreground="White"/>
                        <TextBlock Grid.Column="1" Text="Nová akce" VerticalAlignment="Center" FontWeight="Medium"/>
                    </Grid>
                </Button>

                <!-- STAV filters -->
                <TextBlock Text="STAV" Style="{StaticResource EyebrowText}" Margin="10,22,10,6"/>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByStatusCommand}" CommandParameter="Planned">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="sparkle" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Plánované" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Background="{DynamicResource BgSubtleBrush}" CornerRadius="10" Padding="7,2">
                            <TextBlock Text="{Binding PlannedCount}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource InkSubtleBrush}"/>
                        </Border>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByStatusCommand}" CommandParameter="Running">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="clock" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Probíhající" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Background="{DynamicResource BgSubtleBrush}" CornerRadius="10" Padding="7,2">
                            <TextBlock Text="{Binding RunningCount}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource InkSubtleBrush}"/>
                        </Border>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByStatusCommand}" CommandParameter="Ended">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="check" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Ukončené" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Background="{DynamicResource BgSubtleBrush}" CornerRadius="10" Padding="7,2">
                            <TextBlock Text="{Binding EndedCount}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                                       Foreground="{DynamicResource InkSubtleBrush}"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- PORADATEL filters -->
                <TextBlock Text="POŘADATEL" Style="{StaticResource EyebrowText}" Margin="10,22,10,6"/>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByOrganiserCommand}" CommandParameter="Museum">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="building" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Muzeum" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByOrganiserCommand}" CommandParameter="City">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="building" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Město" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByOrganiserCommand}" CommandParameter="Other">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="users" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Ostatní" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- TYP AKCE filters -->
                <TextBlock Text="TYP AKCE" Style="{StaticResource EyebrowText}" Margin="10,22,10,6"/>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Exhibition">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="grid" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Výstava" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Concert">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="mic" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Koncert" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Theatre">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="theatre" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Divadlo" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Lecture">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="book" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Přednáška" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Workshop">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="briefcase" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Workshop" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="Fair">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="shop" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Trh" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource FilterItem}"
                        Command="{Binding FilterByTypeCommand}" CommandParameter="SpecialEvent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="sparkles" Size="15" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Speciální akce" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Clear all -->
                <Button Style="{StaticResource FilterItem}" Margin="0,14,0,0"
                        Command="{Binding ClearAllFiltersCommand}"
                        Foreground="{DynamicResource InkSubtleBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ctrl:IconView Grid.Column="0" Kind="close" Size="14" Margin="0,0,10,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Grid.Column="1" Text="Zrušit filtry" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- User footer -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="14,12" Background="{DynamicResource BgSubtleBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                        Background="{DynamicResource AccentTintBrush}">
                    <TextBlock Text="{Binding UserInitials}"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LoggedUserName}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource InkBrush}"/>
                    <TextBlock Text="Správce" FontSize="11" Foreground="{DynamicResource InkSubtleBrush}"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding ToggleThemeCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource InkMutedBrush}"
                        FontSize="11.5" Padding="8,6"
                        ToolTip="Přepnout motiv (světlý / tmavý)"
                        Content="{Binding ThemeLabel}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
