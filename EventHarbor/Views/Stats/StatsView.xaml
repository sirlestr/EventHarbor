<UserControl x:Class="EventHarbor.Views.Stats.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
             d:DataContext="{d:DesignInstance Type=vm:StatsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>

        <Style x:Key="ChartCard" TargetType="Border" BasedOn="{StaticResource StatCard}">
            <Setter Property="Padding" Value="20"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Statistiky" Style="{StaticResource SerifHeading}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,0">
                        <Run Text="Přehled napříč"/>
                        <Run Text="{Binding TotalEvents, Mode=OneWay}"/>
                        <Run Text="akcemi"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Content="Exportovat přehled"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="12,7" FontSize="13" IsEnabled="False"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,20">
            <StackPanel>
                <!-- KPI cards row -->
                <UniformGrid Columns="4" Margin="0,0,0,16">
                    <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="NÁVŠTĚVNÍCI CELKEM" Style="{StaticResource EyebrowText}"/>
                            <TextBlock Text="{Binding TotalVisitors, StringFormat=N0, Mode=OneWay}"
                                       FontFamily="{StaticResource SerifFont}" FontSize="32"
                                       Foreground="{DynamicResource InkBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="Součet přes všechny zaznamenané akce"
                                       FontSize="11.5" Foreground="{DynamicResource InkSubtleBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="USKUTEČNĚNÉ AKCE" Style="{StaticResource EyebrowText}"/>
                            <TextBlock Text="{Binding DoneEvents, Mode=OneWay}"
                                       FontFamily="{StaticResource SerifFont}" FontSize="32"
                                       Foreground="{DynamicResource InkBrush}" Margin="0,6,0,0"/>
                            <TextBlock FontSize="11.5" Foreground="{DynamicResource InkSubtleBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0">
                                <Run Text="Z celkem"/>
                                <Run Text="{Binding TotalEvents, Mode=OneWay}"/>
                                <Run Text="záznamů"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="NÁKLADY" Style="{StaticResource EyebrowText}"/>
                            <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N0} Kč', Mode=OneWay}"
                                       FontFamily="{StaticResource SerifFont}" FontSize="32"
                                       Foreground="{DynamicResource InkBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="Součet nákladů placených akcí"
                                       FontSize="11.5" Foreground="{DynamicResource InkSubtleBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="AKCE ZDARMA" Style="{StaticResource EyebrowText}"/>
                            <TextBlock Text="{Binding FreeCount, Mode=OneWay}"
                                       FontFamily="{StaticResource SerifFont}" FontSize="32"
                                       Foreground="{DynamicResource InkBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding FreeShareLabel, Mode=OneWay}"
                                       FontSize="11.5" Foreground="{DynamicResource InkSubtleBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Chart row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Stacked bar chart -->
                    <Border Grid.Column="0" Style="{StaticResource ChartCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Návštěvnost po měsících" FontFamily="{StaticResource SerifFont}"
                                               FontSize="18" Foreground="{DynamicResource InkBrush}"/>
                                    <TextBlock Text="Rozpad podle kategorií" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendChildrenBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Děti" FontSize="11.5" Foreground="{DynamicResource InkMutedBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendAdultsBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Dospělí" FontSize="11.5" Foreground="{DynamicResource InkMutedBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendSeniorsBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Senioři" FontSize="11.5" Foreground="{DynamicResource InkMutedBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendDisabledBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="ZTP" FontSize="11.5" Foreground="{DynamicResource InkMutedBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Bars -->
                            <ItemsControl ItemsSource="{Binding MonthBars}" Height="210">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Total, StringFormat=N0}"
                                                       FontSize="10.5" FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{DynamicResource InkSubtleBrush}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,4">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Total}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Row="1" VerticalAlignment="Bottom"
                                                        Height="{Binding StackHeight}">
                                                <Border Background="{DynamicResource AttendChildrenBrush}"
                                                        Height="{Binding ChildrenPx}"/>
                                                <Border Background="{DynamicResource AttendAdultsBrush}"
                                                        Height="{Binding AdultsPx}"/>
                                                <Border Background="{DynamicResource AttendSeniorsBrush}"
                                                        Height="{Binding SeniorsPx}"/>
                                                <Border Background="{DynamicResource AttendDisabledBrush}"
                                                        Height="{Binding DisabledPx}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="2" Text="{Binding Label}"
                                                       FontSize="11" Foreground="{DynamicResource InkSubtleBrush}"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Donut card -->
                    <Border Grid.Column="2" Style="{StaticResource ChartCard}">
                        <StackPanel>
                            <TextBlock Text="Podle pořadatele" FontFamily="{StaticResource SerifFont}"
                                       FontSize="18" Foreground="{DynamicResource InkBrush}"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,16">
                                <Run Text="Návštěvnost · celkem"/>
                                <Run Text="{Binding OrganiserTotalVisitors, StringFormat=N0, Mode=OneWay}"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:DonutChart Grid.Column="0" Slices="{Binding OrganiserSlices}"
                                                 Width="120" Height="120" Margin="0,0,16,0"/>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding OrganiserSlices}"
                                              VerticalAlignment="Center">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="2" Margin="0,0,8,0"
                                                        Background="{Binding ColorHex, Converter={StaticResource HexToBrushConverter}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12.5"
                                                           Foreground="{DynamicResource InkBrush}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Visitors, StringFormat=N0}"
                                                           FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{DynamicResource InkMutedBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TOP 5 card -->
                <Border Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Text="Nejnavštěvovanější akce" FontFamily="{StaticResource SerifFont}"
                                   FontSize="18" Foreground="{DynamicResource InkBrush}"/>
                        <TextBlock Text="TOP 5 podle počtu návštěvníků" FontSize="12"
                                   Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,14"/>
                        <ItemsControl ItemsSource="{Binding TopEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto" MinWidth="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                                Background="{DynamicResource AccentTintBrush}">
                                            <TextBlock Text="{Binding Rank}" FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                   Foreground="{DynamicResource InkBrush}" Margin="12,0,12,0"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Height="6" CornerRadius="3"
                                                Background="{DynamicResource BgSubtleBrush}"
                                                VerticalAlignment="Center" Margin="0,0,12,0" ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding FillPct, Converter={StaticResource PctToStarConverter}}"/>
                                                    <ColumnDefinition Width="{Binding FillPct, Converter={StaticResource InversePctToStarConverter}}"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="3"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center">
                                            <Run Text="{Binding Total, StringFormat=N0, Mode=OneWay}"
                                                 FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                                                 Foreground="{DynamicResource InkBrush}" FontWeight="Medium"/>
                                            <Run Text="návštěvníků" FontSize="11.5"
                                                 Foreground="{DynamicResource InkSubtleBrush}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Zatím nejsou zaznamenané žádné akce s návštěvností."
                                   FontSize="12" Foreground="{DynamicResource InkSubtleBrush}"
                                   HorizontalAlignment="Center" Margin="0,10"
                                   Visibility="{Binding TopEvents.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
