<Window x:Class="EventHarbor.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
        Title="EventHarbor"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderStrongBrush}"
            BorderThickness="1" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.18" ShadowDepth="4" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="24,20,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                        Background="{DynamicResource CopperTintBrush}" Margin="0,0,12,0">
                    <ctrl:IconView x:Name="IconControl" Kind="bell" Size="16"
                                   Foreground="{DynamicResource CopperBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TitleText"
                           FontFamily="{StaticResource SerifFont}" FontSize="19"
                           Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="2" Click="Cancel_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="6" VerticalAlignment="Top" Cursor="Hand">
                    <ctrl:IconView Kind="close" Size="14"
                                   Foreground="{DynamicResource InkSubtleBrush}"/>
                </Button>
            </Grid>

            <!-- Body -->
            <TextBlock Grid.Row="1" x:Name="MessageText"
                       Margin="24,10,24,20"
                       FontSize="13" Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap" LineHeight="20"/>

            <!-- Buttons -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Background="{DynamicResource BgSubtleBrush}" CornerRadius="0,0,10,10"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" x:Name="CancelButton" Click="Cancel_Click"
                            Background="{DynamicResource BgElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="14,7" FontSize="13" Margin="0,0,8,0"
                            IsCancel="True"/>
                    <Button Grid.Column="2" x:Name="ConfirmButton" Click="Confirm_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White" BorderThickness="0"
                            Padding="16,7" FontSize="13" FontWeight="Medium"
                            IsDefault="True"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
