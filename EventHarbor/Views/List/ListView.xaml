<UserControl x:Class="EventHarbor.Views.List.ListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             xmlns:domain="clr-namespace:EventHarbor.Domain"
             xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
             xmlns:cmn="clr-namespace:EventHarbor.Common"
             d:DataContext="{d:DesignInstance Type=vm:ListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <!-- Chip button style -->
        <Style x:Key="FilterChip" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource BgSubtleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveFilterChip" TargetType="Button" BasedOn="{StaticResource FilterChip}">
            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- View toggle button -->
        <Style x:Key="ViewToggle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="ViewMode"/>
            <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="B" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource InkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Akce" Style="{StaticResource SerifHeading}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource InkSubtleBrush}" Margin="0,2,0,0">
                        <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                        <Run Text="z"/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        <Run Text="záznamů"/>
                    </TextBlock>
                </StackPanel>

                <!-- Search -->
                <Border Grid.Column="2" Background="{DynamicResource BgSubtleBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,12,0" MinWidth="220" VerticalAlignment="Center">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             Background="Transparent" BorderThickness="0"
                             Padding="10,6" FontSize="13"
                             VerticalAlignment="Center"/>
                </Border>

                <!-- View toggle -->
                <Border Grid.Column="3" Background="{DynamicResource BgSubtleBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="3" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource ViewToggle}" Content="Tabulka"
                                     IsChecked="{Binding ViewMode, Converter={StaticResource RouteToBoolConverter}, ConverterParameter=Table}"
                                     Command="{Binding SetViewModeCommand}" CommandParameter="Table"/>
                        <RadioButton Style="{StaticResource ViewToggle}" Content="Karty" IsEnabled="False"/>
                        <RadioButton Style="{StaticResource ViewToggle}" Content="Kalendář" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <!-- Export -->
                <Button Grid.Column="4" Content="Export"
                        Background="{DynamicResource BgElevatedBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="12,7" FontSize="13" Margin="0,0,8,0"
                        IsEnabled="False"/>

                <!-- New action -->
                <Button Grid.Column="5" Content="Nová akce"
                        Command="{Binding NewCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="14,7" FontSize="13" FontWeight="Medium"/>
            </Grid>
        </Border>

        <!-- Body: content + detail panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Content area -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter chips -->
                <Border Grid.Row="0" Background="{DynamicResource BgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="20,12">
                    <WrapPanel>
                        <TextBlock Text="PŘIHLÁŠENÍ" Style="{StaticResource EyebrowText}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                        <TextBlock Text="POŘADATEL" Style="{StaticResource EyebrowText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Muzeum"
                                Command="{Binding ToggleOrganiserCommand}" CommandParameter="Museum">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterOrganiser}" Value="Museum">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Město"
                                Command="{Binding ToggleOrganiserCommand}" CommandParameter="City">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterOrganiser}" Value="City">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Ostatní"
                                Command="{Binding ToggleOrganiserCommand}" CommandParameter="Other">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterOrganiser}" Value="Other">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,2,10,2"/>

                        <TextBlock Text="STAV" Style="{StaticResource EyebrowText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Plánováno"
                                Command="{Binding ToggleStatusCommand}" CommandParameter="Planned">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterStatus}" Value="Planned">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Probíhá"
                                Command="{Binding ToggleStatusCommand}" CommandParameter="Running">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterStatus}" Value="Running">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Ukončeno"
                                Command="{Binding ToggleStatusCommand}" CommandParameter="Ended">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterChip}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterStatus}" Value="Ended">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding EventsView}"
                          SelectedItem="{Binding SelectedEvent}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          SelectionMode="Single"
                          RowBackground="Transparent"
                          AlternatingRowBackground="Transparent"
                          Background="{DynamicResource BgBrush}"
                          BorderThickness="0"
                          RowHeight="44">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Akce" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                                                   Foreground="{DynamicResource InkBrush}"/>
                                        <TextBlock FontSize="11" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource InkSubtleBrush}">
                                            <Run Text="{Binding DisplayId}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Type, Converter={StaticResource EnumDescriptionConverter}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Pořadatel" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgSubtleBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="3" Padding="8,3" Margin="6,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Organiser, Converter={StaticResource EnumDescriptionConverter}}"
                                                   FontSize="11.5" Foreground="{DynamicResource InkMutedBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Termín" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0">
                                        <TextBlock Text="{Binding StartAt, StringFormat='dd.MM.yyyy'}"
                                                   FontSize="12" Foreground="{DynamicResource InkBrush}"/>
                                        <TextBlock Text="{Binding StartAt, StringFormat='HH:mm'}"
                                                   FontSize="11" Foreground="{DynamicResource InkSubtleBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Návštěvnost" Binding="{Binding TotalAttendance}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Náklady" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Right" Margin="6,0">
                                        <TextBlock Text="{Binding Cost, StringFormat='{}{0:N0} Kč'}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="13"
                                                   Foreground="{DynamicResource InkBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Background="{DynamicResource CopperTintBrush}"
                                                CornerRadius="3" Padding="8,2">
                                            <TextBlock Text="zdarma" FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource CopperBrush}"/>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Stav" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="8,3" Margin="6,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource BgSubtleBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Planned">
                                                        <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="Background" Value="{DynamicResource MossTintBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"
                                                   FontSize="11.5" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Planned">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Foreground" Value="{DynamicResource MossBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Nic jsme nenašli" Style="{StaticResource SerifHeading}" FontSize="20"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Zkuste upravit hledaný výraz nebo vypnout filtry."
                               Style="{StaticResource SubtleText}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Detail panel -->
            <Border Grid.Column="1" Background="{DynamicResource BgElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid DataContext="{Binding SelectedEvent}">
                    <!-- Empty state when no selection -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Vyberte akci" Style="{StaticResource SerifHeading}" FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Klikněte na řádek v tabulce pro zobrazení detailu."
                                   Style="{StaticResource SubtleText}" HorizontalAlignment="Center" Margin="0,4,0,0"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Detail content when selected -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Head -->
                        <StackPanel Grid.Row="0" Margin="20,18,20,14">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border CornerRadius="3" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BgSubtleBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Planned">
                                                    <Setter Property="Background" Value="{DynamicResource AccentTintBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                    <Setter Property="Background" Value="{DynamicResource MossTintBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status, Converter={StaticResource EnumDescriptionConverter}}"
                                               FontSize="11.5" FontWeight="Medium"
                                               Foreground="{DynamicResource InkMutedBrush}"/>
                                </Border>
                                <Border CornerRadius="3" Padding="8,3" Margin="6,0,0,0"
                                        Background="{DynamicResource CopperTintBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Zdarma" FontSize="11.5" FontWeight="Medium"
                                               Foreground="{DynamicResource CopperBrush}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource SerifFont}"
                                       FontSize="22" Foreground="{DynamicResource InkBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DisplayId}" FontFamily="{StaticResource MonoFont}"
                                       FontSize="11" Foreground="{DynamicResource InkSubtleBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Body scroll -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0">
                            <StackPanel>
                                <!-- Termin -->
                                <TextBlock Text="TERMÍN" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Od" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding StartAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                               FontSize="13" Foreground="{DynamicResource InkBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Do" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding EndAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                               FontSize="13" Foreground="{DynamicResource InkBrush}"/>
                                </Grid>

                                <!-- Zarazeni -->
                                <TextBlock Text="ZAŘAZENÍ" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Typ akce" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Type, Converter={StaticResource EnumDescriptionConverter}}"
                                               FontSize="13" Foreground="{DynamicResource InkBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Typ výstavy" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Exhibition, Converter={StaticResource EnumDescriptionConverter}}"
                                               FontSize="13" Foreground="{DynamicResource InkBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Pořadatel" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding Organiser, Converter={StaticResource EnumDescriptionConverter}}"
                                               FontSize="13" Foreground="{DynamicResource InkBrush}"/>
                                </Grid>

                                <!-- Navstevnost -->
                                <TextBlock Style="{StaticResource EyebrowText}" Margin="0,0,0,8">
                                    <Run Text="NÁVŠTĚVNOST · CELKEM "/>
                                    <Run Text="{Binding TotalAttendance, Mode=OneWay}"/>
                                </TextBlock>
                                <ctrl:AttendanceBar Event="{Binding}" BarHeight="8" Margin="0,0,0,10"/>
                                <UniformGrid Columns="2" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendChildrenBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                        <TextBlock Text="Děti" FontSize="12" Foreground="{DynamicResource InkMutedBrush}"/>
                                        <TextBlock Text="{Binding Children}" FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource InkBrush}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendAdultsBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                        <TextBlock Text="Dospělí" FontSize="12" Foreground="{DynamicResource InkMutedBrush}"/>
                                        <TextBlock Text="{Binding Adults}" FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource InkBrush}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendSeniorsBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                        <TextBlock Text="Senioři" FontSize="12" Foreground="{DynamicResource InkMutedBrush}"/>
                                        <TextBlock Text="{Binding Seniors}" FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource InkBrush}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" Background="{DynamicResource AttendDisabledBrush}" CornerRadius="2" Margin="0,0,8,0"/>
                                        <TextBlock Text="ZTP" FontSize="12" Foreground="{DynamicResource InkMutedBrush}"/>
                                        <TextBlock Text="{Binding Disabled}" FontSize="12" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource InkBrush}" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </UniformGrid>

                                <!-- Finance -->
                                <TextBlock Text="FINANCE" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Náklady" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Cost, StringFormat='{}{0:N2} Kč'}"
                                               FontSize="13" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{DynamicResource InkBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Vstupné" FontSize="12"
                                               Foreground="{DynamicResource InkSubtleBrush}" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="13"
                                               Foreground="{DynamicResource InkBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Placené"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                        <Setter Property="Text" Value="Zdarma"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Poznamky -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Notes}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="POZNÁMKY" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource BgSubtleBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="12" Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"
                                                   FontSize="13" Foreground="{DynamicResource InkMutedBrush}"
                                                   LineHeight="20"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer actions (bound to ListViewModel commands) -->
                        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="20,14"
                                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Smazat"
                                        Command="{Binding DeleteCommand}"
                                        Background="{DynamicResource BgSubtleBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource CopperBrush}"
                                        Padding="12,6" FontSize="12"/>
                                <Button Grid.Column="2" Content="Upravit"
                                        Command="{Binding EditCommand}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White" BorderThickness="0"
                                        Padding="14,6" FontSize="12" FontWeight="Medium"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
