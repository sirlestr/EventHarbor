<UserControl x:Class="EventHarbor.Views.Auth.ForgotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
             d:DataContext="{d:DesignInstance Type=vm:ForgotViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgElevatedBrush}">
    <StackPanel Margin="40,44,40,28">
        <TextBlock Text="Zapomenuté heslo" Style="{StaticResource SerifTitle}"/>
        <TextBlock Text="Ověřte se pomocí bezpečnostní otázky, kterou jste si zvolili při registraci."
                   Style="{StaticResource SubtleText}" Margin="0,6,0,26" TextWrapping="Wrap"/>

        <!-- Verification block -->
        <StackPanel Visibility="{Binding IsVerified, Converter={StaticResource BoolToVisInvertedConverter}}">
            <TextBlock Text="UŽIVATELSKÉ JMÉNO" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13.5" Padding="10,8" Margin="0,0,0,16"/>

            <TextBlock Text="BEZPEČNOSTNÍ OTÁZKA" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding AvailableQuestions}"
                      SelectedItem="{Binding SecurityQuestion}"
                      FontSize="13.5" Padding="10,8" Margin="0,0,0,16"/>

            <TextBlock Text="ODPOVĚĎ" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13.5" Padding="10,8"/>
            <TextBlock Text="Odpověď musí přesně odpovídat té z registrace (case-insensitive)."
                       Style="{StaticResource SubtleText}" Margin="0,4,0,18" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource CopperBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,6,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Command="{Binding VerifyCommand}"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Padding="14,11" FontSize="14" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ctrl:IconView Kind="check" Size="14" Margin="0,0,8,0" Foreground="White"/>
                    <TextBlock Text="Ověřit odpověď" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Reset block - shown after verify -->
        <StackPanel Visibility="{Binding IsVerified, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{DynamicResource MossTintBrush}"
                    BorderBrush="{DynamicResource MossBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="✓ Odpověď ověřena" Foreground="{DynamicResource MossBrush}"
                               FontWeight="Medium" FontSize="13"/>
                    <TextBlock Text="Nyní nastavte nové heslo."
                               Foreground="{DynamicResource MossBrush}" Opacity="0.85"
                               FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="NOVÉ HESLO" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="NewPwdBox" FontSize="13.5" Padding="10,8" Margin="0,0,0,16"
                         PasswordChanged="NewPwdBox_PasswordChanged"/>

            <TextBlock Text="NOVÉ HESLO ZNOVU" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="NewPwdConfirmBox" FontSize="13.5" Padding="10,8"
                         PasswordChanged="NewPwdConfirmBox_PasswordChanged"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource CopperBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,10,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Command="{Binding ResetCommand}"
                    IsDefault="True"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Padding="14,11" FontSize="14" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ctrl:IconView Kind="check" Size="14" Margin="0,0,8,0" Foreground="White"/>
                    <TextBlock Text="Uložit nové heslo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Back link -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="0,14,0,0" Margin="0,24,0,0">
            <TextBlock HorizontalAlignment="Center" FontSize="12.5">
                <Hyperlink Command="{Binding GoToLoginCommand}" Foreground="{DynamicResource AccentBrush}" TextDecorations="{x:Null}">
                    <Run Text="← Zpět na přihlášení"/>
                </Hyperlink>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
