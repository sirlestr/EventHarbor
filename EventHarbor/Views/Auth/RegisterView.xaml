<UserControl x:Class="EventHarbor.Views.Auth.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:RegisterViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgElevatedBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,44,40,28">
            <TextBlock Text="Vytvořit účet" Style="{StaticResource SerifTitle}"/>
            <TextBlock Text="Připojte se ke správě kulturního programu."
                       Style="{StaticResource SubtleText}" Margin="0,6,0,26"/>

            <!-- Username -->
            <TextBlock Text="UŽIVATELSKÉ JMÉNO" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13.5" Padding="10,8"/>
            <TextBlock Text="3–32 znaků, bez diakritiky." Style="{StaticResource SubtleText}" Margin="0,4,0,16"/>

            <!-- Password -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="HESLO" Style="{StaticResource EyebrowText}"/>
                <TextBlock Text="{Binding PasswordStrengthLabel}"
                           HorizontalAlignment="Right" FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource AccentBrush}"
                           Visibility="{Binding Password, Converter={StaticResource StringToVisibilityConverter}}"/>
            </Grid>
            <PasswordBox x:Name="PwdBox" FontSize="13.5" Padding="10,8" Margin="0,0,0,6"
                         PasswordChanged="PwdBox_PasswordChanged"/>
            <!-- Strength bar: 4 ticks -->
            <Grid Height="3" Margin="0,0,0,16"
                  Visibility="{Binding Password, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,2,0" CornerRadius="1.5"
                        Background="{Binding PasswordStrength, Converter={StaticResource StrengthTickConverter}, ConverterParameter=1}"/>
                <Border Grid.Column="1" Margin="2,0,2,0" CornerRadius="1.5"
                        Background="{Binding PasswordStrength, Converter={StaticResource StrengthTickConverter}, ConverterParameter=2}"/>
                <Border Grid.Column="2" Margin="2,0,2,0" CornerRadius="1.5"
                        Background="{Binding PasswordStrength, Converter={StaticResource StrengthTickConverter}, ConverterParameter=3}"/>
                <Border Grid.Column="3" Margin="2,0,0,0" CornerRadius="1.5"
                        Background="{Binding PasswordStrength, Converter={StaticResource StrengthTickConverter}, ConverterParameter=4}"/>
            </Grid>

            <!-- Password confirm -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="HESLO ZNOVU" Style="{StaticResource EyebrowText}"/>
                <TextBlock HorizontalAlignment="Right" FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource MossBrush}"
                           Text="✓ Shoda"
                           Visibility="{Binding PasswordsMatch, Converter={StaticResource BoolToVisConverter}}"/>
            </Grid>
            <PasswordBox x:Name="PwdConfirmBox" FontSize="13.5" Padding="10,8"
                         PasswordChanged="PwdConfirmBox_PasswordChanged"/>
            <TextBlock Text="⚠ Hesla se neshodují" FontSize="11.5" Margin="0,4,0,0"
                       Foreground="{DynamicResource CopperBrush}"
                       Visibility="{Binding PasswordsMismatch, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- Divider -->
            <Grid Margin="0,22,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="1" Background="{DynamicResource BorderBrush}"/>
                <TextBlock Grid.Column="1" Text="OBNOVA HESLA" Margin="10,0"
                           Style="{StaticResource EyebrowText}"/>
                <Border Grid.Column="2" Height="1" Background="{DynamicResource BorderBrush}"/>
            </Grid>

            <!-- Security question -->
            <TextBlock Text="BEZPEČNOSTNÍ OTÁZKA" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding AvailableQuestions}"
                      SelectedItem="{Binding SecurityQuestion}"
                      FontSize="13.5" Padding="10,8"/>
            <TextBlock Text="Použije se při zapomenutí hesla."
                       Style="{StaticResource SubtleText}" Margin="0,4,0,16"/>

            <!-- Security answer -->
            <TextBlock Text="ODPOVĚĎ" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
            <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13.5" Padding="10,8"/>
            <TextBlock Text="Odpověď se porovnává case-insensitive (malá/velká písmena nerozhodují). Bez mezer na krajích."
                       Style="{StaticResource SubtleText}" Margin="0,4,0,18" TextWrapping="Wrap"/>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource CopperBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,6,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- Actions -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Zpět"
                        Command="{Binding GoToLoginCommand}"
                        Padding="14,11" FontSize="14" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Vytvořit účet"
                        Command="{Binding RegisterCommand}"
                        IsDefault="True"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="14,11" FontSize="14"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
