<UserControl x:Class="EventHarbor.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EventHarbor.ViewModels"
             xmlns:ctrl="clr-namespace:EventHarbor.Common.Controls"
             d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{DynamicResource BgElevatedBrush}">
    <StackPanel Margin="40,44,40,28" VerticalAlignment="Stretch">
        <TextBlock Text="Vítejte zpět" Style="{StaticResource SerifTitle}"/>
        <TextBlock Text="Přihlaste se do správy kulturních akcí."
                   Style="{StaticResource SubtleText}" Margin="0,6,0,28"/>

        <!-- Username -->
        <TextBlock Text="UŽIVATELSKÉ JMÉNO" Style="{StaticResource EyebrowText}" Margin="0,0,0,6"/>
        <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="13.5" Padding="10,8" Margin="0,0,0,16"/>

        <!-- Password row with "forgot" link -->
        <Grid Margin="0,0,0,6">
            <TextBlock Text="HESLO" Style="{StaticResource EyebrowText}"/>
            <TextBlock HorizontalAlignment="Right">
                <Hyperlink Command="{Binding GoToForgotCommand}" Foreground="{DynamicResource AccentBrush}" TextDecorations="{x:Null}">
                    <Run Text="Zapomenuté heslo?" FontSize="11.5"/>
                </Hyperlink>
            </TextBlock>
        </Grid>
        <PasswordBox x:Name="PwdBox" FontSize="13.5" Padding="10,8" Margin="0,0,0,14"
                     PasswordChanged="PwdBox_PasswordChanged"/>

        <!-- Remember -->
        <CheckBox Content="Zůstat přihlášen na tomto zařízení"
                  IsChecked="{Binding RememberMe}"
                  Margin="0,0,0,8" FontSize="13"
                  Foreground="{DynamicResource InkMutedBrush}"/>

        <!-- Error -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource CopperBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,6,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Primary action -->
        <Button Command="{Binding LoginCommand}"
                IsDefault="True"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                FontSize="14"
                Padding="14,11"
                HorizontalAlignment="Stretch"
                BorderThickness="0"
                Margin="0,12,0,22">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ctrl:IconView Kind="arrow" Size="14" Margin="0,0,8,0" Foreground="White"/>
                <TextBlock Text="Přihlásit se" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Register link at bottom -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0"
                VerticalAlignment="Bottom">
            <TextBlock HorizontalAlignment="Center" FontSize="12.5" Foreground="{DynamicResource InkSubtleBrush}">
                <Run Text="Nemáte účet? "/>
                <Hyperlink Command="{Binding GoToRegisterCommand}" Foreground="{DynamicResource AccentBrush}" TextDecorations="{x:Null}">
                    <Run Text="Zaregistrujte se"/>
                </Hyperlink>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
