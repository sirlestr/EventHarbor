<Application x:Class="EventHarbor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:cnv="clr-namespace:EventHarbor.Common"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light"/>
                <ui:ControlsDictionary/>
                <ResourceDictionary Source="Themes/Colors.Light.xaml"/>
                <ResourceDictionary Source="Themes/Typography.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <cnv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <cnv:StrengthTickConverter x:Key="StrengthTickConverter"/>
            <cnv:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
            <cnv:BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
            <cnv:BooleanToVisibilityConverter x:Key="BoolToVisInvertedConverter" Invert="True"/>
            <cnv:RouteToBoolConverter x:Key="RouteToBoolConverter"/>
            <cnv:BoolInvertConverter x:Key="BoolInvertConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
